# ───────────────────────── Telegram ─────────────────────────
# Токен бота от @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Telegram user_id администраторов через запятую.
# Узнать свой user_id можно у @userinfobot.
# Если оставить пустым — бот будет доступен всем.
ADMIN_IDS=123456789

# ───────────────────────── 2328.io ─────────────────────────
# Project UUID и API key из личного кабинета 2328.io.
PROJECT_UUID=240478b4-0519-44c8-9cd5-c5ffa3a58a03
API_KEY=your_api_key_here

# Базовый URL API (можно не менять).
API_BASE_URL=https://api.2328.io/api/v1

# User-Agent для запросов к API.
API_USER_AGENT=TgBot2328/1.0 (+https://github.com/)

# URL для webhook-уведомлений от 2328.io (необязательно).
CALLBACK_URL=

# URL успешной оплаты / возврата (необязательно).
SUCCESS_URL=
RETURN_URL=

# ───────────────────────── Поведение бота ─────────────────────────
DEFAULT_CURRENCY=USD
DEFAULT_TTL=3600
LIST_LIMIT=10

# Таймауты (сек).
REQUEST_TIMEOUT=30
LONG_POLL_TIMEOUT=30
